{
    "name": "@anolilab/models-database",
    "version": "0.0.0",
    "description": "TypeScript package for accessing and searching AI model information from models.dev (SST project)",
    "keywords": [
        "ai",
        "models",
        "database",
        "search",
        "llm",
        "openai",
        "anthropic",
        "models.dev",
        "sst"
    ],
    "homepage": "https://github.com/anolilab/packem/tree/main/packages/models-database",
    "bugs": {
        "url": "https://github.com/anolilab/ai-chat/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/anolilab/ai-chat.git",
        "directory": "packages/models-database"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
            "url": "https://anolilab.com/support"
        }
    ],
    "license": "MIT",
    "author": {
        "name": "Daniel Bannert",
        "email": "d.bannert@anolilab.de"
    },
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "default": "./dist/index.mjs"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "scripts": {
        "build": "packem build --development",
        "build:prod": "packem build --production",
        "clean": "rimraf node_modules dist .eslintcache",
        "dev": "pnpm run build --watch",
        "download": "node scripts/download.js",
        "examples:basic": "node examples/basic-usage.js",
        "examples:details": "node examples/model-details.js",
        "examples:pricing": "node examples/pricing-comparison.js",
        "examples:providers": "node examples/provider-info.js",
        "examples:search": "node examples/search-filters.js",
        "lint:eslint": "eslint .",
        "lint:eslint:fix": "eslint . --fix",
        "lint:package-json": "publint --strict",
        "lint:types": "tsc --noEmit",
        "prepack": "pnpm run build",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui --coverage.enabled=true",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "^16.2.15",
        "@anolilab/semantic-release-pnpm": "2.0.2",
        "@anolilab/semantic-release-preset": "^11.0.2",
        "@secretlint/secretlint-rule-preset-recommend": "^10.2.0",
        "@total-typescript/ts-reset": "^0.6.1",
        "@types/node": "24.0.12",
        "@visulima/packem": "^1.28.2",
        "@vitest/coverage-v8": "^3.2.4",
        "@vitest/ui": "^3.2.4",
        "conventional-changelog-conventionalcommits": "9.1.0",
        "esbuild": "^0.25.6",
        "eslint": "^9.30.1",
        "rimraf": "^6.0.1",
        "secretlint": "10.2.0",
        "semantic-release": "^24.2.6",
        "typescript": "^5.8.3",
        "vitest": "^3.2.4"
    },
    "engines": {
        "node": ">=20.* <=24.*"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    }
}