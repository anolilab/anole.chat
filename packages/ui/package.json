{
    "name": "@anole/ui",
    "version": "1.0.0",
    "private": true,
    "sideEffects": [
        "**/*.css"
    ],
    "exports": {
        "./components/*": "./src/components/*.tsx",
        "./icons/*": "./src/icons/*.tsx",
        "./utils/*": "./src/utils/*.ts",
        "./hooks/*": "./src/hooks/*.ts",
        "./global.css": "./src/global.css"
    },
    "files": [
        "./src/globals.css"
    ],
    "scripts": {
        "clean": "rimraf node_modules dist .eslintcache",
        "lint:eslint": "eslint . --cache --cache-location .eslint.cache.json",
        "lint:eslint:fix": "eslint . --fix --cache --cache-location .eslint.cache.json",
        "lint:prettier": "prettier .",
        "lint:prettier:fix": "prettier --write .",
        "lint:types": "tsc --noEmit"
    },
    "dependencies": {
        "@radix-ui/react-icons": "^1.3.2",
        "@radix-ui/react-slot": "^1.2.3",
        "@tailwindcss/typography": "^0.5.16",
        "@tanstack/form-core": "^1.17.0",
        "@tanstack/match-sorter-utils": "^8.19.4",
        "@tanstack/react-form": "^1.17.0",
        "@tanstack/react-table": "^8.21.3",
        "@tanstack/react-virtual": "^3.13.12",
        "@uidotdev/usehooks": "^2.4.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "1.1.1",
        "date-fns": "^4.1.0",
        "embla-carousel-react": "^8.6.0",
        "input-otp": "^1.4.2",
        "jsonfile": "^6.1.0",
        "lucide-react": "^0.536.0",
        "motion": "^12.23.12",
        "next-themes": "^0.4.6",
        "postcss": "^8.5.6",
        "radix-ui": "1.4.2",
        "react-day-picker": "9.8.1",
        "react-icons": "^5.5.0",
        "react-number-format": "^5.4.4",
        "recharts": "^3.1.1",
        "sonner": "^2.0.7",
        "tailwind-merge": "3.3.1",
        "tailwindcss": "^4.1.11",
        "tw-animate-css": "^1.3.6",
        "vaul": "^1.1.2"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "16.2.23",
        "@anolilab/prettier-config": "6.0.3",
        "eslint": "9.32.0",
        "prettier": "^3.6.2",
        "prettier-plugin-tailwindcss": "0.6.14",
        "react": "19.1.1",
        "react-dom": "19.1.1",
        "rimraf": "^6.0.1",
        "typescript": "^5.9.2"
    }
