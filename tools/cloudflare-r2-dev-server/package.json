{
    "name": "cloudflare-r2-dev-server",
    "private": true,
    "type": "module",
    "exports": "./dist/index.mjs",
    "scripts": {
        "build": "packem build --development",
        "build:prod": "packem build --production",
        "dev": "pnpm run build && node ./dist/index.mjs",
        "lint:eslint": "eslint . --cache --cache-location .eslint.cache.json",
        "lint:eslint:fix": "eslint . --fix --cache --cache-location .eslint.cache.json",
        "start": "node ./dist/index.mjs"
    },
    "dependencies": {
        "@hono/node-server": "^1.18.1",
        "hono": "^4.8.12",
        "sqlite3": "^5.1.7"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "16.2.23",
        "@visulima/packem": "2.0.0-alpha.2",
        "eslint": "9.32.0",
        "typescript": "^5.9.2"
    },
    "engines": {
        "node": ">=24"
    }
}
