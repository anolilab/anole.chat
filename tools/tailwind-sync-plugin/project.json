{
    "name": "tailwind-sync-plugin",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "tools/tailwind-sync-plugin/src",
    "projectType": "library",
    "tags": [],
    "targets": {
        "build": {
            "executor": "@nx/js:tsc",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "dist/tools/tailwind-sync-plugin",
                "main": "tools/tailwind-sync-plugin/src/index.ts",
                "tsConfig": "tools/tailwind-sync-plugin/tsconfig.lib.json",
                "assets": [
                    "tools/tailwind-sync-plugin/*.md",
                    {
                        "input": "./tools/tailwind-sync-plugin/src",
                        "glob": "**/!(*.ts)",
                        "output": "./src"
                    },
                    {
                        "input": "./tools/tailwind-sync-plugin/src",
                        "glob": "**/*.d.ts",
                        "output": "./src"
                    },
                    {
                        "input": "./tools/tailwind-sync-plugin",
                        "glob": "generators.json",
                        "output": "."
                    },
                    {
                        "input": "./tools/tailwind-sync-plugin",
                        "glob": "executors.json",
                        "output": "."
                    }
                ]
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint"
        },
        "test": {
            "executor": "@nx/vite:test",
            "outputs": ["{options.reportsDirectory}"],
            "options": {
                "reportsDirectory": "../../coverage/tools/tailwind-sync-plugin"
            }
        }
    }
}
