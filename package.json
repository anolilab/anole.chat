{
    "name": "anole",
    "version": "0.0.0",
    "private": true,
    "license": "MIT",
    "author": {
        "name": "Daniel Bannert",
        "url": "https://github.com/anolilab/ai-chat"
    },
    "contributors": [
        {
            "name": "Daniel Bannert",
            "url": "https://github.com/anolilab/ai-chat"
        }
    ],
    "type": "module",
    "workspaces": [
        "app",
        "convex",
        "packages/*",
        "tools/**"
    ],
    "scripts": {
        "audit": "audit-ci --config ./audit-ci.jsonc",
        "build:affected:packages": "nx affected --target=build --nxBail",
        "build:affected:prod:packages": "nx affected --target=build:prod --nxBail",
        "build:chat": "nx run chat:build",
        "build:packages": "nx run-many --target=build --parallel --projects=tag:type:package",
        "build:packages:prod": "nx run-many --target=build:prod --parallel --projects=tag:type:package",
        "dev:chat": "nx run-many --target=dev --parallel --projects=chat,convex,cloudflare-r2-dev-server",
        "preinstall": "node -e \"if(process.env.CI == 'true') {console.info('Skipping preinstall...')} else {process.exit(1)}\" || (node verify-node-version.js && npm -y exec only-allow pnpm)",
        "lint": "pnpm run lint:prettier && pnpm run lint:eslint && lint:dedupe --check",
        "lint:dedupe": "pnpm dedupe --check",
        "lint:eslint": "nx run-many --target=lint:eslint --all --parallel",
        "lint:eslint:fix": "nx run-many --target=lint:eslint:fix --all --parallel",
        "lint:prettier": "pnpm run lint:prettier:root && nx run-many --target=lint:prettier --all --parallel",
        "lint:prettier:fix": "pnpm run lint:prettier:fix:root && nx run-many --target=lint:prettier:fix --all --parallel",
        "lint:secrets": "secretlint **/*",
        "lint:staged": "lint-staged --verbose --concurrent false --debug",
        "lint:types": "nx run-many --target=lint:types --all --parallel",
        "nx": "nx",
        "sort-package-json": "sort-package-json packages/**/package.json local/**/package.json app/package.json convex/package.json ./package.json"
    },
    "dependencies": {
        "@anolilab/commitlint-config": "^6.0.2",
        "@anolilab/lint-staged-config": "^3.0.25",
        "@anolilab/prettier-config": "6.0.3",
        "@commitlint/cli": "^19.8.1",
        "@commitlint/config-conventional": "^19.8.1",
        "@nx/devkit": "21.3.0",
        "@nx/workspace": "21.3.0",
        "@secretlint/secretlint-rule-preset-recommend": "^10.2.1",
        "audit-ci": "^7.1.0",
        "commitizen": "^4.3.1",
        "dotenv": "17.2.0",
        "husky": "^9.1.7",
        "is-ci": "^4.1.0",
        "lint-staged": "^16.1.2",
        "nx": "21.3.0",
        "prettier": "^3.6.2",
        "prettier-plugin-tailwindcss": "0.6.14",
        "secretlint": "10.2.1",
        "sort-package-json": "^3.4.0",
        "typescript": "^5.8.3"
    },
    "packageManager": "pnpm@10.13.1",
    "devDependencies": {
        "@eslint/js": "^9.31.0",
        "@nx/eslint": "21.3.0",
        "@nx/eslint-plugin": "21.3.0",
        "@nx/js": "21.3.0",
        "@nx/plugin": "21.3.0",
        "@nx/vite": "21.3.0",
        "@nx/web": "21.3.0",
        "@swc-node/register": "~1.10.10",
        "@swc/cli": "~0.7.8",
        "@swc/core": "~1.13.0",
        "@swc/helpers": "~0.5.17",
        "@types/node": "24.0.14",
        "@vitest/coverage-v8": "^3.2.4",
        "@vitest/ui": "^3.2.4",
        "eslint": "^9.31.0",
        "eslint-config-prettier": "^10.1.8",
        "jiti": "2.4.2",
        "jsdom": "~26.1.0",
        "jsonc-eslint-parser": "^2.4.0",
        "tslib": "^2.8.1",
        "typescript-eslint": "^8.37.0",
        "vite": "^7.0.5",
        "vitest": "^3.2.4"
    }
}
