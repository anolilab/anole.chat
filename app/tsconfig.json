{
    "extends": "../tsconfig.base.json",
    "compilerOptions": {
        "jsx": "react-jsx",
        "types": ["vite/client"],

        /* Bundler mode */
        "moduleResolution": "bundler",

        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"],
            "@convex/*": ["./convex/*"]
        }
    },
    "include": ["**/*.ts", "**/*.tsx", "eslint.config.js", "prettier.config.js", "vite.config.js"]
}
