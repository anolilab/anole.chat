{
    "extends": "../tsconfig.base.json",
    "compilerOptions": {
        "jsx": "react-jsx",
        "baseUrl": ".",
        /* Bundler mode */
        "moduleResolution": "bundler",
        "paths": {
            "@/*": ["./src/*"]
        },
        "types": ["vite/client", "@vitest/browser/matchers"]
    },
    "include": ["**/*.ts", "**/*.tsx", "eslint.config.js", "prettier.config.js", "vite.config.js"],
    "exclude": ["**/*.md", "**/*.json"]
}
