{
    "extends": "../tsconfig.base.json",
    "compilerOptions": {
        "jsx": "react-jsx",
        "baseUrl": ".",
        /* Bundler mode */
        "moduleResolution": "bundler",
        "paths": {
            "@/*": ["./src/*"]
        },
        "types": ["vite/client", "@vitest/browser/matchers", "vitest/globals"]
    },
    "references": [
        {
            "path": "../packages/ui/tsconfig.json"
        }
    ],
    "include": [
        "**/*.ts",
        "**/*.tsx",
        "eslint.config.js",
        "prettier.config.js",
        "vite.config.js",
        "@vitest/browser/providers/webdriverio",
        "../packages/ui/src/hooks/use-hydrated.ts"
    ],
    "exclude": ["**/*.md", "**/*.json"]
}
