        "dev:vite": "vite dev --port 5173",
        "email:dev": "email dev --dir src/components/emails --port 5555",
        "env:clear": "npx convex env unset",
        "env:generate-encryption": "node scripts/generate-encryption-key.js",
        "env:list": "npx convex env list",
        "lint:prettier:fix": "prettier --write .",
        "lint:types": "tsc --noEmit",
        "serve": "vite preview",
        "start": "node .output/server/index.mjs",
        "sync:env": "node scripts/sync-env-to-convex.js",
        "sync:env:local": "node scripts/sync-env-to-convex.js --env=development",
        "test": "vitest run",
        "translate:clean": "lingui extract --clean",
        "translate:extract": "lingui extract"
    },
