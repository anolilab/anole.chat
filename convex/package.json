{
    "name": "@anole/convex",
    "version": "1.0.0",
    "private": true,
    "description": "Convex backend for AI Chat application.",
    "license": "FSL-1.1-ALv2",
    "author": {
        "name": "Daniel Bannert",
        "url": "https://github.com/anolilab/ai-chat"
    },
    "contributors": [
        {
            "name": "Daniel Bannert",
            "url": "https://github.com/anolilab/ai-chat"
        }
    ],
    "type": "module",
    "exports": {
        "./api": {
            "types": "./convex/_generated/api.d.ts",
            "default": "./convex/_generated/api.js"
        },
        "./server": {
            "types": "./convex/_generated/server.d.ts",
            "default": "./convex/_generated/server.js"
        },
        "./dataModel": {
            "types": "./convex/_generated/dataModel.d.ts"
        },
        "./auth": "./convex/auth.ts",
        "./ai/lib/*": "./convex/ai/lib/*",
        "./package.json": "./package.json"
    },
    "scripts": {
        "clean": "rimraf node_modules dist .eslintcache",
        "dev": "CONVEX_TRACE_FILE=true convex dev --local --typecheck=disable --tail-logs",
        "lint:eslint": "eslint .",
        "lint:eslint:fix": "eslint . --fix",
        "lint:prettier": "prettier .",
        "lint:prettier:fix": "prettier --write .",
        "lint:types": "tsc --noEmit"
    },
    "dependencies": {
        "@ai-sdk/anthropic": "^2.0.0",
        "@ai-sdk/fal": "^1.0.2",
        "@ai-sdk/google": "^2.0.1",
        "@ai-sdk/groq": "^2.0.1",
        "@ai-sdk/openai": "^2.0.2",
        "@ai-sdk/provider": "^2.0.0",
        "@ai-sdk/react": "^2.0.2",
        "@ai-sdk/ui-utils": "^1.2.11",
        "@convex-dev/action-cache": "^0.2.11",
        "@convex-dev/agent": "0.1.17",
        "@convex-dev/better-auth": "^0.7.13",
        "@convex-dev/migrations": "^0.2.9",
        "@convex-dev/polar": "^0.6.1",
        "@convex-dev/r2": "^0.7.1",
        "@convex-dev/rate-limiter": "^0.2.12",
        "@convex-dev/resend": "0.1.7",
        "@convex-dev/workflow": "^0.2.5",
        "@openrouter/ai-sdk-provider": "^0.7.3",
        "@react-email/components": "0.4.0",
        "@react-email/render": "^1.1.4",
        "ai": "^5.0.2",
        "better-auth": "1.3.4",
        "convex": "^1.25.4",
        "convex-helpers": "^0.1.101",
        "hono": "^4.8.12",
        "react": "19.1.1",
        "react-dom": "19.1.1",
        "resend": "^4.8.0",
        "zod": "4.0.14"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "16.2.23",
        "@anolilab/prettier-config": "6.0.3",
        "@eslint-react/eslint-plugin": "^1.52.3",
        "@types/node": "^24.2.0",
        "@types/react": "^19.1.9",
        "@types/react-dom": "^19.1.7",
        "eslint": "9.32.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-compiler": "19.1.0-rc.2",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-perf": "^3.3.3",
        "eslint-plugin-react-refresh": "^0.4.20",
        "eslint-plugin-react-you-might-not-need-an-effect": "^0.4.1",
        "eslint-plugin-validate-jsx-nesting": "^0.1.1",
        "eslint-plugin-zod": "^1.4.0",
        "prettier": "^3.6.2",
        "rimraf": "^6.0.1",
        "typescript": "^5.9.2"
    }
}
