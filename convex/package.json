{
    "name": "@anole/convex",
    "version": "1.0.0",
    "private": true,
    "description": "Convex backend for AI Chat application.",
    "license": "FSL-1.1-ALv2",
    "author": {
        "name": "Daniel Bannert",
        "url": "https://github.com/anolilab/ai-chat"
    },
    "contributors": [
        {
            "name": "Daniel Bannert",
            "url": "https://github.com/anolilab/ai-chat"
        }
    ],
    "type": "module",
    "exports": {
        "./api": {
            "types": "./convex/_generated/api.d.ts",
            "default": "./convex/_generated/api.js"
        },
        "./server": {
            "types": "./convex/_generated/server.d.ts",
            "default": "./convex/_generated/server.js"
        },
        "./dataModel": {
            "types": "./convex/_generated/dataModel.d.ts"
        },
        "./auth": "./convex/auth.ts",
        "./ai/lib/*": "./convex/ai/lib/*",
        "./package.json": "./package.json"
    },
    "scripts": {
        "dev": "convex dev --local --typecheck=disable",
        "lint": "eslint . --ext .ts,.tsx",
        "lint:eslint": "eslint . --cache --cache-location .eslint.cache.json",
        "lint:eslint:fix": "eslint . --fix --cache --cache-location .eslint.cache.json",
        "lint:prettier": "prettier .",
        "lint:prettier:fix": "prettier --write .",
        "lint:types": "tsc --noEmit"
    },
    "dependencies": {
        "@ai-sdk/anthropic": "^1.2.12",
        "@ai-sdk/fal": "^0.1.12",
        "@ai-sdk/google": "^1.2.19",
        "@ai-sdk/groq": "^1.2.9",
        "@ai-sdk/openai": "^1.3.22",
        "@ai-sdk/provider": "^1.1.3",
        "@ai-sdk/react": "^1.2.12",
        "@ai-sdk/ui-utils": "^1.2.11",
        "@convex-dev/action-cache": "^0.2.10",
        "@convex-dev/agent": "0.1.14",
        "@convex-dev/better-auth": "^0.7.0",
        "@convex-dev/migrations": "^0.2.9",
        "@convex-dev/r2": "^0.7.0",
        "@convex-dev/rate-limiter": "^0.2.10",
        "@convex-dev/resend": "0.1.3",
        "@convex-dev/workflow": "^0.2.5",
        "@openrouter/ai-sdk-provider": "^0.7.2",
        "@react-email/components": "0.3.1",
        "@react-email/render": "^1.1.3",
        "ai": "^4.3.17",
        "better-auth": "1.2.12",
        "convex": "^1.25.2",
        "convex-helpers": "^0.1.99",
        "hono": "^4.8.4",
        "react": "19.1.0",
        "react-dom": "19.1.0",
        "resend": "^4.6.0",
        "zod": "4.0.5"
    },
    "devDependencies": {
        "@anolilab/eslint-config": "16.2.19",
        "@anolilab/prettier-config": "6.0.3",
        "@eslint-react/eslint-plugin": "^1.52.2",
        "@types/node": "^24.0.13",
        "@types/react": "^19.1.8",
        "@types/react-dom": "^19.1.6",
        "eslint": "9.31.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-compiler": "19.1.0-rc.2",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-perf": "^3.3.3",
        "eslint-plugin-react-refresh": "^0.4.20",
        "eslint-plugin-react-you-might-not-need-an-effect": "^0.4.1",
        "eslint-plugin-validate-jsx-nesting": "^0.1.1",
        "eslint-plugin-zod": "^1.4.0",
        "prettier": "^3.6.2",
        "typescript": "^5.8.3"
    }
}
