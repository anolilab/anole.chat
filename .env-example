CONVEX_DEPLOYMENT=anonymous:anonymous-ai-chat

# HTTP Actions URL
VITE_CONVEX_SITE_URL="http://127.0.0.1:3211"

VITE_SITE_URL="http://localhost:5173"

# AI Provider
ANTHROPIC_API_KEY=
VERCEL_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Email Provider
RESEND_API_KEY=
RESEND_FROM_EMAIL="AI Chat <onboarding@anolilab.com>"

# Payment provider
POLAR_ACCESS_TOKEN=
POLAR_SUCCESS_URL="success?checkout_id={CHECKOUT_ID}"
POLAR_WEBHOOK_SECRET=

# Cloudflare R2 Storage (for file uploads)
# FOR LOCAL DEVELOPMENT with nitro-cloudflare-dev:
# Use these placeholder values - nitro-cloudflare-dev will handle R2 simulation locally
# R2_TOKEN=local-dev-token
# R2_ACCESS_KEY_ID=local-dev-access-key
# R2_SECRET_ACCESS_KEY=local-dev-secret-key
# R2_ENDPOINT=http://localhost:4902
# R2_BUCKET=ai-chat-files

# FOR PRODUCTION: Get these values from your Cloudflare R2 dashboard after creating an API token
R2_TOKEN=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=ai-chat-files

# PostHog Analytics
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Additional environment variables (found in codebase)
SITE_URL="http://localhost:5173"
ENCRYPTION_KEY=
